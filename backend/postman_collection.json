{
  "info": {
    "name": "ResearchMind AI - Document Intelligence",
    "description": "API Testing for RAG Document Pipeline",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/health",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "health"]
        },
        "description": "Check API health status and vector DB connection"
      },
      "response": []
    },
    {
      "name": "Upload PDF",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": "path/to/your/document.pdf"
            }
          ]
        },
        "url": {
          "raw": "{{BASE_URL}}/api/v1/upload",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "upload"]
        },
        "description": "Upload and process a PDF document"
      },
      "response": []
    },
    {
      "name": "Ask Question",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"What are the main findings in this document?\",\n  \"top_k\": 5,\n  \"document_id\": null\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/v1/ask",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "ask"]
        },
        "description": "Ask a question about uploaded documents"
      },
      "response": []
    },
    {
      "name": "List Documents",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/documents",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "documents"]
        },
        "description": "List all uploaded documents"
      },
      "response": []
    },
    {
      "name": "Get Document Details",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/documents/{{DOCUMENT_ID}}",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "documents", "{{DOCUMENT_ID}}"]
        },
        "description": "Get metadata for a specific document"
      },
      "response": []
    },
    {
      "name": "Delete Document",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/api/v1/documents/{{DOCUMENT_ID}}",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "v1", "documents", "{{DOCUMENT_ID}}"]
        },
        "description": "Delete a document and its embeddings"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:8000"
    },
    {
      "key": "DOCUMENT_ID",
      "value": ""
    }
  ]
}
